# docker-compose.yml에서 사용하는 값입니다. 실제 값은 .env에 넣고 커밋하지 않습니다.
POSTGRES_PASSWORD=runvas
POSTGRES_PORT=5432
REDIS_PORT=6379

# backend 서비스는 `docker compose --profile deploy up -d`로 배포할 때만 사용합니다.
# 로컬 개발(./gradlew bootRun)에는 영향 없습니다.
JWT_SECRET=dev-secret-dev-secret-dev-secret-dev-secret
JWT_EXPIRATION_SECONDS=3600
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
TMAP_APP_KEY=
UPLOAD_BASE_URL=http://localhost:8921
