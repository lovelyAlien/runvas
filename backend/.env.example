# 서버 포트 — 팀 공용 기본값은 8080. 로컬 환경(다른 프로젝트와 포트 충돌 등)에서만
# 이 값을 바꿔 쓰고, 공용 application.yml의 기본값은 건드리지 않는다.
SERVER_PORT=8080

# JWT — 최소 32자 임의 문자열
# 발급: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION_SECONDS=3600

# Database — docker-compose 기본값
DATABASE_URL=jdbc:postgresql://localhost:5432/runvas
DATABASE_USERNAME=runvas
DATABASE_PASSWORD=runvas

# Redis — docker-compose 기본값
REDIS_HOST=localhost
REDIS_PORT=6379

# 카카오 개발자 콘솔 (https://developers.kakao.com)
# 앱 선택 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=
# 앱 선택 → 보안 → Client Secret (사용 상태: 활성화 필요)
KAKAO_CLIENT_SECRET=

# T-Map 개발자 콘솔 (https://openapi.sk.com) — 보행자 경로 탐색 API
# 값이 비어 있으면 백엔드가 T-Map 호출 실패(401) 후 직선 폴백으로 동작한다.
TMAP_APP_KEY=

# 코스 대댓글 이미지 업로드 — 로컬 파일 저장 경로와, 저장된 이미지의 공개 접근 URL prefix.
# BASE_URL은 SERVER_PORT와 값을 맞춰야 한다.
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080
