# JWT — 최소 32자 임의 문자열
# 발급: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION_SECONDS=3600

# Database — docker-compose 기본값
DATABASE_URL=jdbc:postgresql://localhost:5432/runvas
DATABASE_USERNAME=runvas
DATABASE_PASSWORD=runvas

# Redis — docker-compose 기본값
REDIS_HOST=localhost
REDIS_PORT=6379

# 카카오 개발자 콘솔 (https://developers.kakao.com)
# 앱 선택 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=
# 앱 선택 → 보안 → Client Secret (사용 상태: 활성화 필요)
KAKAO_CLIENT_SECRET=
