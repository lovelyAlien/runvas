EXPO_PUBLIC_KAKAO_APP_KEY=   # 카카오 로그인용 REST API 키 (네이티브 앱 키 아님)
EXPO_PUBLIC_KAKAO_JS_KEY=    # 카카오 지도 SDK용 JavaScript 키 (REST API 키와 다른 값, 사이트 도메인 등록 필요)
EXPO_PUBLIC_API_BASE_URL=

# Kakao Redirect URI (Expo Go WebView 방식 고정값)
# 카카오 개발자 콘솔 > 카카오 로그인 > Redirect URI 에 아래 값을 등록하세요:
#   http://localhost/oauth/kakao/callback
